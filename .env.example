# ============================================
# POFFBANK PAYMENT GATEWAY - ENVIRONMENT CONFIGURATION
# ============================================

# Server Configuration
NODE_ENV=production
PORT=10000
BASE_URL=https://poffbank-api.onrender.com
FRONTEND_URL=https://carlin5.netlify.app

# ============================================
# NOWPAYMENTS API KEYS
# ============================================
# Primary API Key for payments
NOWPAYMENTS_API_KEY=VB6E96H-VSFM9M2-MFETDV4-RY6JM7K

# Secondary/Backup API Key (optional)
NOWPAYMENTS_API_KEY_SECONDARY=FXY3NBV-E4MMGSM-GB7GTVT-Q8HK2FP

# IPN signing secret — REQUIRED for webhook verification.
# Set this in: NOWPayments dashboard → Store Settings → IPN Secret Key
# Must match exactly. Without it, /api/webhook/nowpayments will reject all callbacks.
NOWPAYMENTS_IPN_SECRET=replace-with-value-from-nowpayments-dashboard

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/poffbank?retryWrites=true&w=majority

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
WEBHOOK_SECRET=your-webhook-signature-secret
ENCRYPTION_KEY=your-encryption-key-32-chars

# ============================================
# POFFBRAND CONFIGURATION
# ============================================
COMPANY_NAME=PoffBank
COMPANY_LOGO_URL=https://poffbank.com/logo.png
SUPPORT_EMAIL=support@poffbank.com
DEFAULT_CURRENCY=USD
DEFAULT_CRYPTO_CURRENCY=usdttrc20

# ============================================
# DIRECT-TO-WALLET PAYMENTS (USDT TRC-20)
# ============================================
# The merchant wallet that customers using "Pay direct (USDT)" send to.
USDT_TRC20_WALLET=TURXbzSQQKTiA6fqMzsZMaFQyXAU7o2nXh

# Tether (USDT) TRC-20 contract on Tron mainnet. Override only if testing.
USDT_TRC20_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# TronGrid API key — optional. Without it, public TronGrid endpoints are used
# at the free rate limit. Get one at https://www.trongrid.io/dashboard
# TRONGRID_API_KEY=

# ============================================
# MULTI-COIN PAYOUT WALLETS
# ============================================
# Set whichever you have. Empty = method/coin hidden in /api/config.
# USDT_TRC20_WALLET above is already set.
USDT_POLYGON_WALLET=
BTC_WALLET=
ETH_WALLET=

# ============================================
# BITCART (self-hosted, no-KYB) — optional
# ============================================
# To enable a third "Self-hosted (Bitcart)" payment method on /pay.html,
# stand up a Bitcart instance (see BITCART_SETUP.md) and fill in all four:
#
#   1) BITCART_API_URL       — admin panel URL, e.g. https://admin.pay.example.com
#   2) BITCART_API_TOKEN     — Bitcart "Manage Tokens" → Server Management token
#   3) BITCART_STORE_ID      — id of the Bitcart store that holds your wallets
#   4) BITCART_WEBHOOK_SECRET — random string also set in Bitcart store webhook
#
# Missing any of these → the Bitcart option is hidden and the app falls back
# to NOWPayments + direct USDT only. Existing flows are unaffected.
# BITCART_API_URL=
# BITCART_API_TOKEN=
# BITCART_STORE_ID=
# BITCART_WEBHOOK_SECRET=
# Optional override if your public checkout URL differs from the admin URL:
# BITCART_CHECKOUT_URL_TEMPLATE=https://pay.example.com/i/{id}

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CARD → USDT ON-RAMP
# ============================================
# How customers pay with a Visa / Mastercard / Amex card and have it settle as
# USDT (TRC-20) directly in USDT_TRC20_WALLET. Picks the first available
# provider, in order:
#
#   1. transak          — partner API key (REQUIRES merchant KYB)
#   2. moonpay          — partner API key (REQUIRES merchant KYB)
#   3. nowpayments-card — NOWPayments hosted invoice's built-in card option
#                         (powered by Simplex / Mercuryo). NO MERCHANT KYB
#                         needed beyond a basic NOWPayments account.
#                         (default fallback, set CARD_ONRAMP_NOWPAYMENTS_FALLBACK=false to disable)
#   4. moonpay-public   — MoonPay's public consumer "Buy USDT" URL with
#                         walletAddress pre-filled. NO merchant account at all.
#                         (default fallback, set CARD_ONRAMP_MOONPAY_PUBLIC=false to disable)
#
# Customer-side KYC is always handled by the on-ramp provider — card data
# never touches this server.
#
# To use the NO-KYB nowpayments-card fallback (recommended starting point):
#   a) Go to NOWPayments dashboard → Store Settings → Payment Methods
#      → enable "Buy crypto with card (Simplex / Mercuryo)"
#   b) NOWPayments dashboard → Payment Settings → set USDT-TRC20 payout wallet
#      to TURXbzSQQKTiA6fqMzsZMaFQyXAU7o2nXh
#   c) Set NOWPAYMENTS_IPN_SECRET (above) so we receive signed status callbacks
#
# To later switch to branded Transak / MoonPay (after you pass their KYB),
# uncomment and fill the relevant TRANSAK_* or MOONPAY_* keys below.

# Transak (https://docs.transak.com) — requires merchant KYB
# TRANSAK_API_KEY=
# TRANSAK_ENVIRONMENT=STAGING                    # or PRODUCTION
# TRANSAK_WEBHOOK_SECRET=                        # REQUIRED if TRANSAK_API_KEY set
# TRANSAK_CRYPTO_CODE=USDT
# TRANSAK_NETWORK=tron

# MoonPay partner API (https://dev.moonpay.com) — requires merchant KYB
# MOONPAY_API_KEY=
# MOONPAY_SECRET_KEY=                            # REQUIRED if MOONPAY_API_KEY set
# MOONPAY_ENVIRONMENT=sandbox                    # or production
# MOONPAY_CURRENCY_CODE=usdt_trx

# No-KYB fallbacks (both default to enabled). Set to "false" to disable:
# CARD_ONRAMP_NOWPAYMENTS_FALLBACK=true
# CARD_ONRAMP_MOONPAY_PUBLIC=true

# ============================================
# OPTIONAL: STRIPE (for card processing if needed)
# ============================================
# NOTE: Stripe is included here for completeness but is NOT used by this
# gateway. The card → USDT path uses the on-ramp providers above.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# OPTIONAL: FLUTTERWAVE (for African markets)
# ============================================
# FLUTTERWAVE_SECRET_KEY=FLWSECK-...
# FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-...
# FLUTTERWAVE_ENCRYPTION_KEY=...
